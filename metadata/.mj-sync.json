{
  "version": "1.0.0",
  "push": {
    "autoCreateMissingRecords": true
  },
  "directoryOrder": [
    "schema-info",
    "address-types",
    "contact-types",
    "organization-types",
    "relationship-types",
    "entities"
  ],
  "sqlLogging": {
    "enabled": true,
    "outputDirectory": "./sql_logging",
    "filterPatterns": ["*spCreateAIPromptRun*", "*spUpdateAIPromptRun*"],
    "filterType": "exclude",
    "formatAsMigration": false
  },
  "emitSyncNotes": false
}
