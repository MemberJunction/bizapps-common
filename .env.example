# BizApps Common — environment configuration
# Copy to `.env` at the repo root (apps/MJAPI/.env is a symlink to it) and fill in.
#
# ─────────────────────────────────────────────────────────────────────────────
# DATABASE PLATFORM
# ─────────────────────────────────────────────────────────────────────────────
# BizApps Common installs into an existing MemberJunction database and supports
# BOTH SQL Server and PostgreSQL, exactly like MemberJunction itself.
#
#   DB_PLATFORM=sqlserver    (default — runs the migrations in ./migrations)
#   DB_PLATFORM=postgresql   (runs the converted migrations in ./migrations-pg)
#
# The MJ CLI reads DB_PLATFORM and, for PostgreSQL, automatically swaps the
# migrations folder (migrations -> migrations-pg) — no other config change is
# needed. PostgreSQL targets include AWS Aurora / RDS, Cloud SQL, and Azure.
DB_PLATFORM=sqlserver

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE CONNECTION
# ─────────────────────────────────────────────────────────────────────────────
DB_HOST=localhost
# SQL Server default port is 1433; PostgreSQL default is 5432.
DB_PORT=1433
DB_DATABASE=YourMJDatabase
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Migrations and CodeGen connect with the CodeGen login (needs DDL privileges).
CODEGEN_DB_USERNAME=your_codegen_username
CODEGEN_DB_PASSWORD=your_codegen_password

# SQL Server / managed-cert convenience (ignored by PostgreSQL):
DB_TRUST_SERVER_CERTIFICATE=true
DB_ENCRYPT=false

# ─────────────────────────────────────────────────────────────────────────────
# GRAPHQL SERVER
# ─────────────────────────────────────────────────────────────────────────────
GRAPHQL_PORT=4101

# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION (configure MSAL or Auth0 — see docs/getting-started.md)
# ─────────────────────────────────────────────────────────────────────────────
# Auth0:
# AUTH0_DOMAIN=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# Azure AD / MSAL:
# TENANT_ID=
# WEB_CLIENT_ID=
