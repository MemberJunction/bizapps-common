{
  "name": "bizapps-common",
  "version": "1.0.0",
  "license": "ISC",
  "description": "BizApps Common - Common business application entities (Person, Organization, Address, ContactMethod, Relationship) built on MemberJunction",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prebuild": "node -e \"try { require.resolve('turbo') } catch (e) { console.error('\\n❌ Dependencies not installed. Run: npm install\\n'); process.exit(1); }\"",
    "build": "npm run build:stream",
    "build:stream": "turbo --log-order=stream build",
    "build:generated": "turbo --log-order=stream build --filter=\"@mj-biz-apps/common-entities\" --filter=\"@mj-biz-apps/common-actions\"",
    "build:packages": "turbo --log-order=stream build --filter=\"@mj-biz-apps/common-*\"",
    "build:api": "turbo --log-order=stream build --filter=\"mj_api\"",
    "build:explorer": "turbo --log-order=stream build --filter=\"mj_explorer\"",
    "start": "turbo start --filter=mj_explorer --filter=mj_api",
    "start:api": "turbo start --filter=mj_api",
    "start:explorer": "turbo start --filter=mj_explorer",
    "mj": "node apps/MJAPI/node_modules/@memberjunction/cli/bin/run.js",
    "mj:migrate": "node apps/MJAPI/node_modules/@memberjunction/cli/bin/run.js migrate",
    "mj:codegen": "node apps/MJAPI/node_modules/@memberjunction/cli/bin/run.js codegen",
    "install:deps": "npm install",
    "setup": "echo 'Please run: npm run mj:migrate && npm run mj:codegen && npm run build'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MemberJunction/bizapps-common"
  },
  "packageManager": "npm@10.5.0",
  "devDependencies": {
    "beasties": "0.3.5",
    "mrmime": "2.0.1",
    "rolldown": "1.0.0-beta.58",
    "rollup": "^4.43.0",
    "tsc-alias": "^1.8.16",
    "turbo": "^2.7.3",
    "typescript": "5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=10.0.0"
  }
}
